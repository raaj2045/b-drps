# Copy this file to .env and fill in the values.
# .env is gitignored — never commit secrets.

# ---------------------------------------------------------------------------
# IPFS pinning (Pinata)
# ---------------------------------------------------------------------------
# Sign up at https://app.pinata.cloud and create an API key with
# pinFileToIPFS permission. Paste the JWT (not the API key/secret pair) below.
REACT_APP_PINATA_JWT=

# Pinata gateway hostname (no https://, no /ipfs path).
# Public gateway is rate-limited; create a dedicated gateway at
# https://app.pinata.cloud/gateway for production use.
REACT_APP_PINATA_GATEWAY=gateway.pinata.cloud

# ---------------------------------------------------------------------------
# Frontend RPC endpoint
# ---------------------------------------------------------------------------
# Read-only provider used by the dapp. Default targets the local Hardhat node.
# For Sepolia from the browser, set this to your Infura/Alchemy endpoint --
# this is exposed to the client, so use a public gateway (not the deploy URL).
REACT_APP_RPC_URL=http://127.0.0.1:8545

# ---------------------------------------------------------------------------
# Sepolia fork (read-only; for `npm run test:sepolia-fork` / `node:sepolia-fork`)
# ---------------------------------------------------------------------------
# Full RPC URL used to FORK Sepolia state into the local hardhat network at a
# pinned block. Read-only -- no private key, no funding, no deployer wallet.
# Must serve ARCHIVE state at the pinned block (Alchemy/Infura/QuickNode free
# tiers do; pruned public endpoints like *.publicnode.com do not).
# Any free-tier provider works:
#   Infura:     https://sepolia.infura.io/v3/<PROJECT_ID>
#   Alchemy:    https://eth-sepolia.g.alchemy.com/v2/<API_KEY>
#   QuickNode:  https://<your-endpoint>.quiknode.pro/<token>/
SEPOLIA_RPC_URL=

# Set to 1 to actually fork (the npm scripts do this for you). Left unset,
# default `npm test` / benchmarks run on the fast local network, no RPC needed.
FORK_SEPOLIA=